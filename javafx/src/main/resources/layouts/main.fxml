<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<VBox
  xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  id="main"
  fx:controller="edu.cnm.deepdive.codebreaker.javafx.controller.MainController"
  stylesheets="@../styles/main.css">

  <AnchorPane
    id="title-bar">

    <Text
      id="window-title"
      text="%windowTitle"
      AnchorPane.leftAnchor="0"
      AnchorPane.rightAnchor="0"
      AnchorPane.topAnchor="0"
      AnchorPane.bottomAnchor="0"/>

    <Button
      fx:id="settings"
      text="%settingsLabel"
      onAction="#showSettings"
      styleClass="main-button"
      AnchorPane.rightAnchor="0"
      AnchorPane.bottomAnchor="0"
      AnchorPane.topAnchor="0"/>

  </AnchorPane>

  <HBox
    id="guess-controls">

    <Text
      text="%inputPrompt"/>

    <TextField
      fx:id="guessInput"/>

    <Button
      fx:id="submitGuess"
      text="%submitGuessLabel"
      onAction="#submitGuess"
      styleClass="main-button"/>

  </HBox>

  <HBox
    id="guess-list">

    <ListView
      fx:id="guesses"
      orientation="VERTICAL"
      HBox.hgrow="ALWAYS"/>

  </HBox>

  <HBox
    id="status-bar"/>

  <HBox
    id="button-bar">

    <Button
      fx:id="startGame"
      text="%startGameLabel"
      onAction="#startGame"
      styleClass="main-button"/>

  </HBox>

</VBox>
