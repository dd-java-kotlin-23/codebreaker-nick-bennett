<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/main"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".controller.MainActivity">

  <TextView
    android:id="@+id/pool"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/full_dynamic_spacing"
    style="@style/GameParams"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    tools:text="Pool: ABCDEF"/>

  <TextView
    android:id="@+id/length"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/full_dynamic_spacing"
    style="@style/GameParams"
    app:layout_constraintBaseline_toBaselineOf="@id/pool"
    app:layout_constraintEnd_toEndOf="parent"
    tools:text="Length: 3"/>

  <com.google.android.material.textfield.TextInputLayout
    android:id="@+id/guess_input_layout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/full_dynamic_spacing"
    app:hintEnabled="true"
    app:hintAnimationEnabled="true"
    app:layout_constraintTop_toBottomOf="@id/pool"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toStartOf="@id/submit_guess">

    <com.google.android.material.textfield.TextInputEditText
      android:id="@+id/guess_input"
      android:layout_width="@dimen/guess_input_width"
      android:layout_height="wrap_content"
      android:inputType="text"
      android:hint="@string/guess_input_hint"/>

  </com.google.android.material.textfield.TextInputLayout>

  <Button
    android:id="@+id/submit_guess"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/full_dynamic_spacing"
    android:text="@string/submit_guess_label"
    app:layout_constraintBaseline_toBaselineOf="@id/guess_input_layout"
    app:layout_constraintStart_toEndOf="@id/guess_input_layout"
    app:layout_constraintEnd_toEndOf="parent"/>

  <ListView
    android:id="@+id/guess_list"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:orientation="vertical"
    android:layout_marginTop="@dimen/full_dynamic_spacing"
    app:layout_constraintTop_toBottomOf="@id/guess_input_layout"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>